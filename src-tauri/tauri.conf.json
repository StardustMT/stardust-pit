{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stardust",
  "version": "0.0.1",
  "identifier": "com.stardust.app",
  "build": {
    "beforeDevCommand": "bun --filter stardust-pit-ui dev",
    "beforeBuildCommand": "bun --filter stardust-pit-ui build",
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Stardust",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Live-performance virtual instrument host for the stage.",
    "longDescription": "Stardust is an open-source virtual instrument host built for live performance. Cross-platform on macOS and Windows, with plugin sandboxing for reliability."
  }
}
