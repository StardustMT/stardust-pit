{
  "name": "stardust-pit",
  "private": true,
  "version": "0.0.1",
  "description": "Stardust Pit app — Tauri host (src-tauri/) + React UI (src/). Run bun commands from here.",
  "license": "GPL-3.0-or-later",
  "workspaces": ["src"],
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "ui:dev": "bun --filter stardust-pit-ui dev",
    "ui:build": "bun --filter stardust-pit-ui build",
    "ui:storybook": "bun --filter stardust-pit-ui storybook",
    "ui:build-storybook": "bun --filter stardust-pit-ui build-storybook",
    "ui:eslint": "bun --filter stardust-pit-ui eslint",
    "ui:prettier": "bun --filter stardust-pit-ui prettier",
    "ui:tsc": "bun --filter stardust-pit-ui tsc",
    "ui:test": "bun --filter stardust-pit-ui test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0"
  }
}
